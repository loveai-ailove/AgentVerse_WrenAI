[Unit]
Description=Ask Service For AgentVerse + WrenAI
After=network.target

[Service]
Type=simple
User=lb
WorkingDirectory=/home/lb/data/AgentVerse_WrenAI/ask_service
EnvironmentFile=/home/lb/data/AgentVerse_WrenAI/ask_service/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/lb/data/AgentVerse_WrenAI/.venv/bin/python /home/lb/data/AgentVerse_WrenAI/ask_service/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
