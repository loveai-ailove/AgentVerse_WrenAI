# ask_service 监听地址；本机部署通常保持 127.0.0.1
ASK_HOST=127.0.0.1

# ask_service 监听端口；需要与调用方配置保持一致
ASK_PORT=18082

# vLLM 的 OpenAI 兼容接口地址
VLLM_BASE_URL=http://127.0.0.1:8000/v1

# vLLM 的 API Key；如果模型服务要求鉴权，请填写真实值
VLLM_API_KEY=your-api-key

# 要调用的大模型名称；必须与 /v1/models 返回结果一致
VLLM_MODEL=your-model-name

# Wren 项目根目录；相对 AgentVerse_WrenAI 根目录解析
WREN_PROJECT_PATH=order-demo

# Wren 编译产物 mdl.json 路径；相对 AgentVerse_WrenAI 根目录解析
WREN_MDL_PATH=order-demo/target/mdl.json

# Wren 数据库连接配置文件；相对 AgentVerse_WrenAI 根目录解析
WREN_CONN_FILE=order-demo/connection_info.json

# Wren Memory 索引目录；相对 AgentVerse_WrenAI 根目录解析
WREN_MEMORY_PATH=order-demo/.wren/memory

# 是否启用 Wren 严格模式；推荐 true
WREN_STRICT_MODE=true

# 单次问数请求最大超时时间，单位秒
QUERY_TIMEOUT_SEC=90

# 单次 SQL 最大返回行数，防止结果过大
MAX_RESULT_ROWS=200

# 默认召回的相似问法数量
DEFAULT_RECALL_LIMIT=3

# 默认获取的语义上下文数量
DEFAULT_FETCH_LIMIT=6
